<?xml version="1.0" encoding="UTF-8"?>
<job-scheduling-data xmlns="http://quartznet.sourceforge.net/JobSchedulingData"
                     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                     version="2.0">

  <processing-directives>
    <overwrite-existing-data>true</overwrite-existing-data>
  </processing-directives>

  <schedule>
    <!-- Define the Job Details -->
    <job>
      <name>POGrLineMatchingJob</name>
      <group>Agent</group>
      <description>POGrLineMatching Background Job</description>
      <job-type>Cbsap.Agent.Jobs.POGrLineMatchingJob, Cbsap.Agent</job-type>
    </job>
    <job>
      <name>InvoicePOMatchingJob</name>
      <group>Agent</group>
      <description>InvoicePOMatchingJob Background Job</description>
      <job-type>Cbsap.Agent.Jobs.InvoicePOMatchingJob, Cbsap.Agent</job-type>
    </job>

    <!-- Define the Trigger Execution Rules -->
    <trigger>
      <cron>
        <name>POGrLineMatchingJobTrigger</name>
        <group>Agent</group>
        <job-name>POGrLineMatchingJob</job-name>
        <job-group>Agent</job-group>
        <cron-expression>0 0/5 * 1/1 * ? *</cron-expression>
      </cron>
    </trigger>
    <trigger>
      <cron>
        <name>InvoicePOMatchingJobTrigger</name>
        <group>Agent</group>
        <job-name>InvoicePOMatchingJob</job-name>
        <job-group>Agent</job-group>
        <cron-expression>0 0/6 * 1/1 * ? *</cron-expression>
      </cron>
    </trigger>
  </schedule>
</job-scheduling-data>